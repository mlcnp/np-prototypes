{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/illustrations/**",
              "components/brand/**",
              "components/core/**",
              "ui_kits/discussion/**",
              "ui_kits/hub/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Sans|IBM Plex Mono|DM Sans))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Sans, IBM Plex Mono, DM Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|anonymous|className|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, anonymous, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:tiny|small|medium|large|xl)$/]",
        "message": "<Avatar> size must be one of 'tiny' | 'small' | 'medium' | 'large' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|title|icon|onClose|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Banner> doesn't accept that prop. Declared props: kind, title, icon, onClose, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Banner'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:info|success|warning|suggestion)$/]",
        "message": "<Banner> kind must be one of 'info' | 'success' | 'warning' | 'suggestion'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|iconRight|disabled|fullWidth|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, iconRight, disabled, fullWidth, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|secondary)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'secondary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:lg|sm)$/]",
        "message": "<Button> size must be one of 'lg' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CarbonIdManagement'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<CarbonIdManagement> doesn't accept that prop. Declared props: className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CarbonUser2'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<CarbonUser2> doesn't accept that prop. Declared props: className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CarbonUserFilled'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<CarbonUserFilled> doesn't accept that prop. Declared props: className, style."
