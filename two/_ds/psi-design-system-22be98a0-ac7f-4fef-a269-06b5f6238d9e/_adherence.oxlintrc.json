        "message": "<LoginIllustration> doesn't accept that prop. Declared props: className, style, darkMode, text1, text2, text3, text4, icon1, icon2, icon3, icon4."
      },
      {
        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|site|size|text1|key|ref|className|style|children)$/]",
        "message": "<Logo> doesn't accept that prop. Declared props: className, style, site, size, text1."
