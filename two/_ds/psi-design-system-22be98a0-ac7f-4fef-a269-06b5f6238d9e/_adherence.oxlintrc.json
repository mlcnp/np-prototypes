        "selector": "JSXOpeningElement[name.name='MetadataRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|roleTag|loremIpsumAnyOtherText|timeStamp|originalLanguageTag|postID|edited|text1|text2|text3|text4|icon1|icon2|icon3|key|ref|className|style|children)$/]",
        "message": "<MetadataRow> doesn't accept that prop. Declared props: className, style, roleTag, loremIpsumAnyOtherText, timeStamp, originalLanguageTag, postID, edited, text1, text2, text3, text4, icon1, icon2, icon3."
      },
