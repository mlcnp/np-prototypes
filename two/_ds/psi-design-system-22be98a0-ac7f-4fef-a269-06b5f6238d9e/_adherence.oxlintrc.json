        "selector": "JSXOpeningElement[name.name='OriginalLanguageTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|language|text1|key|ref|className|style|children)$/]",
        "message": "<OriginalLanguageTag> doesn't accept that prop. Declared props: className, style, language, text1."
