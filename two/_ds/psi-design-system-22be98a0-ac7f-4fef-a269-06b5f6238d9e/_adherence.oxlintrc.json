        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Input> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Link'] > JSXAttribute > JSXIdentifier[name!=/^(?:href|size|tone|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Link> doesn't accept that prop. Declared props: href, size, tone, children, className, style."
