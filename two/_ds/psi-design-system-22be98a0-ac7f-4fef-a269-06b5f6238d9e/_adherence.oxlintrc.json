        "selector": "JSXOpeningElement[name.name='SubtleButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|iconRight|selected|disabled|tone|children|className|style|key|ref|className|style|children)$/]",
        "message": "<SubtleButton> doesn't accept that prop. Declared props: icon, iconRight, selected, disabled, tone, children, className, style."
