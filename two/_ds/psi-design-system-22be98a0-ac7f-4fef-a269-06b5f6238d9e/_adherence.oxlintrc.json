        "selector": "JSXOpeningElement[name.name='Logo'] > JSXAttribute[name.name='site'] > Literal[value!=/^(?:zdf|rc|cbc|rts|rtbf|placeholder)$/]",
        "message": "<Logo> site must be one of 'zdf' | 'rc' | 'cbc' | 'rts' | 'rtbf' | 'placeholder'."
